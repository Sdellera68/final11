  "universal_guidelines": {
    "code_style": "React Native StyleSheet objects. NO Tailwind classes (NativeWind not detected).",
    "localization": "All UI text must be in French.",
    "accessibility": "Touch targets minimum 44x44. Contrast ratio > 4.5:1.",
    "testing": "All interactive elements MUST include `data-testid` attribute.",
    "theme_logic": "Force Dark Mode logic in styles (do not rely on system toggle if not robust)."
  },
  "instructions_to_main_agent": [
    "Use the `colors` object to define a `theme.js` file and import it everywhere.",
    "Use `StyleSheet.create` for all styles.",
    "Implement the `TabNavigator` with `expo-blur`.",
    "Ensure all text is in French.",
    "Use the provided image URLs for backgrounds.",
    "Use `Manrope` for headings and `Mulish` for body text (load via `expo-font`)."
  ]
